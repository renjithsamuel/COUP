# Environment
APP_ENV=development
APP_DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./coup.db

# Server
HOST=0.0.0.0
PORT=8000

# Game settings
TURN_TIMER_SECONDS=30
CHALLENGE_WINDOW_SECONDS=5
BLOCK_WINDOW_SECONDS=5
RECONNECT_GRACE_SECONDS=60
MAX_MESSAGES_PER_SECOND=10

# CORS
CORS_ORIGINS=["http://localhost:3000"]
